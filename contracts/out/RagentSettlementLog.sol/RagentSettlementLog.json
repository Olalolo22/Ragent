ansactionId\",\"type\":\"string\"}],\"name\":\"OutcomeLogged\",\"type\":\"event\"},{\"anonymous\":false,\"inputs\":[{\"indexed\":true,\"internalType\":\"bytes32\",\"name\":\"intentId\",\"type\":\"bytes32\"},{\"indexed\":true,\"internalType\":\"uint256\",\"name\":\"agentId\",\"type\":\"uint256\"},{\"indexed\":false,\"internalType\":\"int128\",\"name\":\"score\",\"type\":\"int128\"},{\"indexed\":false,\"internalType\":\"string\",\"name\":\"tag\",\"type\":\"string\"}],\"name\":\"ReputationRecorded\",\"type\":\"event\"},{\"inputs\":[{\"internalType\":\"address\",\"name\":\"\",\"type\":\"address\"}],\"name\":\"isCoordinator\",\"outputs\":[{\"internalType\":\"bool\",\"name\":\"\",\"type\":\"bool\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"bytes32\",\"name\":\"intentId\",\"type\":\"bytes32\"},{\"internalType\":\"address\",\"name\":\"requester\",\"type\":\"address\"},{\"internalType\":\"address\",\"name\":\"provider\",\"type\":\"address\"},{\"internalType\":\"uint256\",\"name\":\"priceUsdc\",\"type\":\"uint256\"},{\"internalType\":\"uint256\",\"name\":\"stakedPenalty\",\"type\":\"uint256\"},{\"internalType\":\"string\",\"name\":\"circleWalletId\",\"type\":\"string\"},{\"internalType\":\"address\",\"name\":\"circleWalletAddr\",\"type\":\"address\"}],\"name\":\"logNegotiationStarted\",\"outputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"bytes32\",\"name\":\"intentId\",\"type\":\"bytes32\"},{\"internalType\":\"bool\",\"name\":\"success\",\"type\":\"bool\"},{\"internalType\":\"bytes32\",\"name\":\"proofHash\",\"type\":\"bytes32\"},{\"internalType\":\"string\",\"name\":\"circleTransactionId\",\"type\":\"string\"}],\"name\":\"logOutcome\",\"outputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"bytes32\",\"name\":\"intentId\",\"type\":\"bytes32\"},{\"internalType\":\"uint256\",\"name\":\"agentId\",\"type\":\"uint256\"},{\"internalType\":\"int128\",\"name\":\"score\",\"type\":\"int128\"},{\"internalType\":\"string\",\"name\":\"tag\",\"type\":\"string\"}],\"name\":\"logReputation\",\"outputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"},{\"inputs\":[],\"name\":\"owner\",\"outputs\":[{\"internalType\":\"address\",\"name\":\"\",\"type\":\"address\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"address\",\"name\":\"coordinator\",\"type\":\"address\"},{\"internalType\":\"bool\",\"name\":\"enabled\",\"type\":\"bool\"}],\"name\":\"setCoordinator\",\"outputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"}],\"devdoc\":{\"details\":\"Pure on-chain audit log for Ragent negotiations. IMPORTANT: This contract holds ZERO funds. The old RagentEscrow.sol held USDC in an unaudited contract \\u2014 requiring users to \\\"trust us.\\\" This contract replaces it entirely. Actual USDC custody is handled by Circle Developer-Controlled Wallets: - A dedicated Circle programmable wallet is created per negotiation. - Circle (a licensed, regulated entity) co-signs all transfers. - Ragent calls Circle's API to release or slash \\u2014 not a transferFrom. - Circle fires a signed Webhook confirming every payment. This contract exists solely to make the negotiation outcome:   1. Permanently verifiable on-chain (immutable event log on Arc).   2. Linkable to the Circle transaction ID for cross-verification.   3. Integrated with Arc's ERC-8004 reputation layer. Anyone can read this contract on ArcScan and cross-reference the Circle transaction ID in Circle's dashboard to verify the payment.\",\"events\":{\"NegotiationStarted(bytes32,address,address,uint256,uint256,string,address)\":{\"params\":{\"circleWalletAddr\":\"The on-chain address of the Circle wallet\",\"circleWalletId\":\"The Circle programmable wallet ID holding the funds\",\"intentId\":\"The unique identifier for this negotiation\",\"priceUsdc\":\"Payment amount (in micro-USDC: 1 USDC = 1_000_000)\",\"provider\":\"Who won the bid\",\"requester\":\"Who posted the job\",\"stakedPenalty\":\"Provider's staked penalty amount\"}},\"OutcomeLogged(bytes32,bool,bytes32,string)\":{\"params\":{\"circleTransactionId\":\"The Circle transaction ID for the payment                            Cross-reference at: https://console.circle.com\",\"intentId\":\"The negotiation this settles\",\"proofHash\":\"Hash of the provider's work proof\",\"success\":\"Whether the SLA was met\"}}},\"kind\":\"dev\",\"methods\":{},\"title\":\"RagentSettlementLog\",\"version\":1},\"userdoc\":{\"events\":{\"NegotiationStarted(bytes32,address,address,uint256,uint256,string,address)\":{\"notice\":\"Emitted when a negotiation begins and a Circle escrow wallet has been created. The walletAddress is where USDC will be sent.\"},\"OutcomeLogged(bytes32,bool,bytes32,string)\":{\"notice\":\"Emitted when an outcome is attested and Circle has been instructed to release or slash the funds.\"},\"ReputationRecorded(bytes32,uint256,int128,string)\":{\"notice\":\"Emitted when reputation is recorded via ERC-8004.\"}},\"kind\":\"user\",\"methods\":{\"logNegotiationStarted(bytes32,address,address,uint256,uint256,string,address)\":{\"notice\":\"Log that a negotiation has started and a Circle escrow wallet has been created to hold the funds.\"},\"logOutcome(bytes32,bool,bytes32,string)\":{\"notice\":\"Log the outcome of a negotiation after Circle has been instructed to release or slash.\"},\"logReputation(bytes32,uint256,int128,string)\":{\"notice\":\"Log that reputation was recorded on ERC-8004.\"}},\"version\":1}},\"settings\":{\"compilationTarget\":{\"src/RagentSettlementLog.sol\":\"RagentSettlementLog\"},\"evmVersion\":\"paris\",\"libraries\":{},\"metadata\":{\"bytecodeHash\":\"ipfs\"},\"optimizer\":{\"enabled\":true,\"runs\":200},\"remappings\":[\":forge-std/=lib/forge-std/src/\"]},\"sources\":{\"src/RagentSettlementLog.sol\":{\"keccak256\":\"0x0688a5cb9599866ed90124c80c3f25844d5770475099e2c94d7c42653dc57f80\",\"l