# ─────────────────────────────────────────────────────────────────────────────
# Ragent Coordinator — Environment Variables
# Copy this to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Arc Testnet ───────────────────────────────────────────────────────────────
USE_TESTNET=true
ARC_RPC=https://rpc.testnet.arc.network           # Arc Testnet RPC
PRIVATE_KEY=0x...                                  # Funded testnet wallet (for viem fallback / traction script)
USDC_ADDRESS=0x3600000000000000000000000000000000000000  # Arc native USDC (leave as-is for testnet)

# ── Circle Trust Layer ────────────────────────────────────────────────────────
# Get these from: https://console.circle.com → Developer Settings → API Keys
CIRCLE_API_KEY=TEST_API_KEY:...                    # Your Circle Test API Key
ENTITY_SECRET=...                                  # Entity secret for Dev-Controlled Wallets

# Get this from: https://console.circle.com → Webhooks → Add Endpoint → Signing Secret
# Webhook URL to register: https://<your-server>/webhooks/circle
CIRCLE_WEBHOOK_SECRET=...                          # HMAC signing secret for webhook verification

# ── OpenAI (optional — enables real LLM agents) ───────────────────────────────
OPENAI_API_KEY=sk-...

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8787
STRICT_SIGNATURES=true                             # Set false only for local dev without signing
